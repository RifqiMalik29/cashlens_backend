# Server Configuration
PORT=8080
# ENVIRONMENT=development
ENVIRONMENT=production

# Database
DATABASE_URL=postgres://cashlens:cashlens_dev@localhost:5432/cashlens?sslmode=disable

# JWT
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRATION=24h
JWT_REFRESH_EXPIRATION=168h
JWT_MAX_REUSE_WINDOW=5m

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=1m
RATE_LIMIT_AUTH_REQUESTS=20
RATE_LIMIT_AUTH_WINDOW=5m

# Logging
LOG_FORMAT=text

# Gemini API (for receipt scanner)
GEMINI_API_KEY=your-gemini-api-key-here

# Telegram Bot (for webhook integration)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# XENDIT
XENDIT_WEBHOOK_TOKEN=your-xendit-callback-token
XENDIT_SECRET_KEY=your-xendit-secret-key
XENDIT_SUCCESS_URL=cashlens://payment/success
XENDIT_FAILURE_URL=cashlens://payment/failed

#Gemini Version
SCANNING_AI=gemini-ai-model
TELEGRAM_AI=gemini-ai-model

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@cashlens.com
BASE_URL=https://your-api-domain.com
MOBILE_DEEPLINK=cashlens://auth/confirm

# Monitoring
SENTRY_DSN=
